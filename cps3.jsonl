{"type": "file", "p": "redearth.zip", "n": "redearth", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/fbnarcade-fullnonmerged/arcade/redearth.zip"}], "meta": {"path": "./redearth.zip", "name": "Red Earth", "desc": "Red Earth tiene lugar en el año 1999 de una Tierra alternativa, sigue las aventuras de cuatro héroes a medida que se enfrentan a un ejército de míticos monstruos desatados por Scion para provocar la destrucción del mundo. Elige entre Leo el Rey León, Mai-Ling el artista Marcial, Tessa la Bruja o Kenji el Ninja mientras luchan por todo el mundo para derrotar a Scion el gigante de hierro.", "genre": "Lucha / Vs Co-op", "image": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/redearth-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/cps3/videos/redearth-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/redearth-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/redearth-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/redearth-fanart.jpg", "bezel": "./images/redearth-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/redearth-boxback.jpg", "rating": "0.8", "releasedate": "19960101T000000", "developer": "Capcom", "publisher": "Capcom", "arcadesystemname": "cps3", "players": "1-2", "md5": "b22ca9d07a33cf0903e606b1659f9824", "lang": "en", "region": "eu"}}
{"type": "file", "p": "sfiii.zip", "n": "sfiii", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/fbnarcade-fullnonmerged/arcade/sfiii.zip"}], "meta": {"path": "./sfiii.zip", "name": "Street Fighter III : New Generation", "desc": "Street Fighter III - ¡Nueva Generación es una Nueva Generación de Street Fighters! Contiene sprites de personajes más grandes que los anteriores juegos de Street Fighter con la animación en 2D más suave y detallada jamás realizada en el momento de su lanzamiento, un nivel de calidad que aún no ha sido igualado por ningún otro juego en 2D fuera de la serie Street Fighter III a partir de 2004; algunos se quejan de que hay demasiadas cosas animadas y cada animación contiene demasiados fotogramas, lo que ralentiza el ritmo del juego.", "genre": "Lucha / Versus", "image": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/cps3/videos/sfiii-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii-fanart.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/cps3/manuals/sfiii-manual.pdf", "bezel": "./images/sfiii-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii-boxback.jpg", "rating": "0.85", "releasedate": "19970201T000000", "developer": "Capcom", "publisher": "Capcom", "family": "Street Fighter", "arcadesystemname": "cps3", "players": "1-2", "md5": "61cd03e226c546e26e0090636de1e267", "lang": "en", "region": "eu"}}
{"type": "file", "p": "sfiii2.zip", "n": "sfiii2", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/fbnarcade-fullnonmerged/arcade/sfiii2.zip"}], "meta": {"path": "./sfiii2.zip", "name": "Street Fighter III : 2nd Impact - Giant Attack", "desc": "Street Fighter III - 2nd Impact: Giant Attack es la continuación de \"Street Fighter III - New Generation\". Hugo, Urien y el personaje recurrente Akuma (Gouki en la versión japonesa) se unen al reparto actual de Street Fighter III. Otras mejoras incluyen un aumento de la velocidad, nuevos movimientos y varios ajustes relacionados con los daños.", "genre": "Lucha / Versus", "image": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii2-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/cps3/videos/sfiii2-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii2-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii2-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii2-fanart.jpg", "bezel": "./images/sfiii2-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/cps3/images/sfiii2-boxback.jpg", "rating": "0.85", "releasedate": "19970930T000000", "developer": "Capcom", "publisher": "Capcom", "family": "Street Fighter", "arcadesystemname": "cps3", "players": "1-2", "md5": "4940f911edfe9c16d96a82005fa6f190", "lang": "en", "region": "us"}}
