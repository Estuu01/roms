{"type": "file", "p": "Deep Sea Adventure (Asia, Europe).rom", "n": "Deep Sea Adventure (Asia, Europe)", "ext": ".rom", "parent": "", "urls": [{"u": "https://archive.org/download/CreatiVision_201809/ROMS.zip/Deep%20Sea%20Adventure%20%28Asia%2C%20Europe%29.rom"}], "meta": {"path": "./Deep Sea Adventure (Asia, Europe).rom", "name": "Deep Sea Adventure", "desc": "Mientras exploras el fondo marino, a miles de pies bajo el agua, las criaturas más desagradables del mar te persiguen. El astuto cangrejo clicklaw, una bestia gigante blindada. La raya con colmillos, un animal enorme y enloquecido. Y el resbaladizo pulpo, con ocho tentáculos gigantes. Todos ellos intentan atacarte sin motivo alguno. Afortunadamente, has recordado llevar contigo tu rayo de la muerte submarino, para que puedas defenderte. Pero recuerda, solo puedes disparar en la dirección en la que te estás moviendo. Así que prepárate para dar la vuelta rápidamente.", "genre": "Shoot'em Up", "image": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Deep Sea Adventure (Asia, Europe)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/crvision/videos/Deep Sea Adventure (Asia, Europe)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Deep Sea Adventure (Asia, Europe)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Deep Sea Adventure (Asia, Europe)-thumb.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/crvision/manuals/Deep Sea Adventure (Asia, Europe)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Deep Sea Adventure (Asia, Europe)-boxback.jpg", "rating": "0.65", "releasedate": "19820101T000000", "developer": "VTech", "publisher": "VTech", "players": "1-2", "md5": "86ea3e8595ebbb51d859322dce4f9dd0", "lang": "en", "region": "eu"}}
