{"type": "file", "p": "Crazy Chicky (Asia, Europe).rom", "n": "Crazy Chicky (Asia, Europe)", "ext": ".rom", "parent": "", "urls": [{"u": "https://archive.org/download/CreatiVision_201809/ROMS.zip/Crazy%20Chicky%20%28Asia%2C%20Europe%29.rom"}], "meta": {"path": "./Crazy Chicky (Asia, Europe).rom", "name": "Crazy Chicky", "desc": "En el mundo encantado hay dos tipos de criaturas: las gallinas y los zorros. Eres un pollo hambriento y quieres comerte las Naranjas y Zanahorias Encantadas. Mantente en guardia, cuatro terribles zorros hambrientos están detrás de ti y quieren devorarte. Ten cuidado porque se mueven más rápido que tú, excepto cerca de las esquinas, porque allí no pueden ver bien.\nCrazy Chicky es una suerte de Pac-man a la inversa en la que debes de dejar tu huella por el camino hasta completar todo el laberinto sin dejar que los zorros te cojan.", "genre": "Acción / Laberinto", "image": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Crazy Chicky (Asia, Europe)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/crvision/videos/Crazy Chicky (Asia, Europe)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Crazy Chicky (Asia, Europe)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Crazy Chicky (Asia, Europe)-thumb.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/crvision/manuals/Crazy Chicky (Asia, Europe)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Crazy Chicky (Asia, Europe)-boxback.jpg", "rating": "0.6", "releasedate": "19810101T000000", "developer": "VTech", "publisher": "VTech", "players": "1-4", "md5": "befc13b9e8151b4ed01b62590190279f", "lang": "en", "region": "eu"}}
