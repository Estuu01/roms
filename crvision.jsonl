{"type": "file", "p": "Police Jump (Asia, Europe).rom", "n": "Police Jump (Asia, Europe)", "ext": ".rom", "parent": "", "urls": [{"u": "https://archive.org/download/CreatiVision_201809/ROMS.zip/Police%20Jump%20%28Asia%2C%20Europe%29.rom"}], "meta": {"path": "./Police Jump (Asia, Europe).rom", "name": "Police Jump", "desc": "En Police Jump encarnas a un inspector de policía con la misión de rescatar a una pobre chica secuestrada por el malvado Dangerous Dan. Escala el rascacielos que sirve de escondite a Dangerous Dan mientras esquivas las bolas que te van lanzando desde arriba en una mecánica similar al famoso Donkey Kong. Hay 20 pisos entre tú y tu destino, y en cada uno de ellos acechan peligros traicioneros.", "genre": "Plataformas / Corre y Salta", "image": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Police Jump (Asia, Europe)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/crvision/videos/Police Jump (Asia, Europe)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Police Jump (Asia, Europe)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Police Jump (Asia, Europe)-thumb.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/crvision/manuals/Police Jump (Asia, Europe)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/crvision/images/Police Jump (Asia, Europe)-boxback.jpg", "rating": "0.4", "releasedate": "19810101T000000", "developer": "VTech", "publisher": "VTech", "players": "1-2", "md5": "abe97e9c838897c924e340ba0160cec8", "lang": "en", "region": "eu"}}
