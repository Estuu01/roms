{"type": "file", "p": "Frantic Freddy (1983)(Spectravideo).zip", "n": "Frantic Freddy (1983)(Spectravideo)", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/Spectravideo_SVI-318_SVI-328_TOSEC_2012_04_23/Spectravideo_SVI-318_SVI-328_TOSEC_2012_04_23.zip/Spectravideo%20SVI-318%20and%20SVI-328%20%5BTOSEC%5D%2FSpectravideo%20SVI-318%20%26%20SVI-328%20-%20Various%20-%20%5BBIN%5D%20%28TOSEC-v2009-09-05_CM%29%2FFrantic%20Freddy%20%281983%29%28Spectravideo%29.zip", "size": "8.92 KB", "size_bytes": 9134}], "meta": {"path": "./Frantic Freddy (1983)(Spectravideo).zip", "name": "Frantic Freddy", "desc": "Frantic Freddy es un juego de acción en el que Freddy debe correr de un lado a otro por el suelo, esquivando la basura que cae mientras apaga las llamas en las ventanas de un edificio. Cuando se apagan todos los incendios, el juego avanza al siguiente piso, donde Freddy puede trepar entre los pisos, disparando hacia la izquierda y la derecha en lugar de hacia arriba. En estos niveles, hay dos tipos de llamas: la roja y la púrpura. Los morados son más agresivos, siguen a Freddy por la pantalla, y solo se pueden apagar una vez que se apagan todos los rojos. El juego avanza de esta manera, alternando entre los niveles de disparo vertical y lateral.", "image": "Z:/Digistorage/Arley4dCloudMedia/spectravideo/images/Frantic Freddy (1983)(Spectravideo)-image.jpg", "marquee": "Z:/Digistorage/Arley4dCloudMedia/spectravideo/images/Frantic Freddy (1983)(Spectravideo)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/spectravideo/images/Frantic Freddy (1983)(Spectravideo)-thumb.jpg", "boxback": "Z:/Digistorage/Arley4dCloudMedia/spectravideo/images/Frantic Freddy (1983)(Spectravideo)-boxback.jpg", "releasedate": "19830101T000000", "md5": "f83abb9b341d94a031466f8813f268e6", "lang": "en", "video": "Z:/Digistorage/Arley4dCloudMedia/spectravideo/videos/Arley4droms.mp4"}, "size_bytes": 9134, "size": "8.92 KB"}
