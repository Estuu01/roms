{"type": "file", "p": "anmlbskt.zip", "n": "anmlbskt", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/atomiswave_nonmerged/Atomiswave/anmlbskt.zip"}], "meta": {"path": "./anmlbskt.zip", "name": "Animal Basket", "desc": "\"Tamaire\" es un juego que tradicionalmente juegan los niños japoneses de primaria en los festivales deportivos. Se necesitan unas 200 bolas rellenas, 2 cestas y 2 postes para sostener las cestas. Puede participar cualquier número de niños. Esta es la versión de videojuego de este juego japonés!", "genre": "Deportes / Baloncesto", "image": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/anmlbskt-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/videos/anmlbskt-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/anmlbskt-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/anmlbskt-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/anmlbskt-fanart.jpg", "bezel": "./images/anmlbskt-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/anmlbskt-boxback.jpg", "rating": "0.7", "releasedate": "20050101T000000", "developer": "MOSS", "publisher": "Sammy Corporation", "arcadesystemname": "atomiswave", "players": "1-2", "md5": "5e79374b20d4dd4dc4c206ac286ce469", "lang": "en", "region": "us"}}
