{"type": "file", "p": "vfurlong.zip", "n": "vfurlong", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/atomiswave_nonmerged/Atomiswave/vfurlong.zip"}], "meta": {"path": "./vfurlong.zip", "name": "Net Select Horse Racing - Victory Furlong", "desc": "Net Select Keiba Victory Furlong (Net Select Horse Racing: Victory Furlong) es un juego arcade de carreras de caballos que a los japoneses les encanta; además, la máquina arcade solo se lanzó en la tierra del sol de Levante. El juego también se juega en línea.", "genre": "Deportes con animales / Carreras de caballos", "image": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/vfurlong-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/videos/vfurlong-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/vfurlong-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/vfurlong-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/vfurlong-fanart.jpg", "bezel": "./images/vfurlong-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/vfurlong-boxback.jpg", "rating": "0.75", "releasedate": "20050101T000000", "developer": "Progress", "publisher": "Sammy Corporation", "arcadesystemname": "atomiswave", "players": "8+", "md5": "36111247b34fe4f9cff6c704c785d052", "lang": "en", "region": "us"}}
{"type": "file", "p": "waidrive.zip", "n": "waidrive", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/atomiswave_nonmerged/Atomiswave/waidrive.zip"}], "meta": {"path": "./waidrive.zip", "name": "WaiWai Drive", "desc": "WaiWai Drive es un juego de coches más bien dirigido al público infantil donde dos coches tendrán que recoger todos los elementos distribuidos por la pantalla tratando de tener más que el enemigo al final de ella.", "genre": "Carreras, Conducción", "image": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/waidrive-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/videos/waidrive-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/waidrive-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/waidrive-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/waidrive-fanart.jpg", "boxback": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/waidrive-boxback.jpg", "rating": "0.5", "releasedate": "20050101T000000", "developer": "MOSS", "publisher": "Sammy Corporation", "arcadesystemname": "atomiswave", "players": "1-2", "md5": "91ad293f5beba5c4926d2d401603aeeb", "lang": "en", "region": "us"}}
{"type": "file", "p": "xtrmhnt2.zip", "n": "xtrmhnt2", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/atomiswave_nonmerged/Atomiswave/xtrmhnt2.zip"}], "meta": {"path": "./xtrmhnt2.zip", "name": "Extreme Hunting 2", "desc": "Embárcate en el viaje de caza de tu vida con Extreme Hunting 2, la continuación de la línea de juegos de caza de Sega Amusements. Una selección de la caza silvestre más prestigiosa de Norteamérica que un cazador puede pedir, incluyendo Bisonte, Oso, Alce, Alce, Ciervo y Lobo, junto con etapas de bonificación con Bajo, Ganso, Murciélago, Ardilla y mucho más. No te pierdas la oportunidad de jugar nuestras siempre cambiantes Cazas Especiales.", "genre": "Disparos con periférico", "image": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhnt2-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/videos/xtrmhnt2-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhnt2-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhnt2-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhnt2-fanart.jpg", "bezel": "./images/xtrmhnt2-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhnt2-boxback.jpg", "rating": "0.75", "releasedate": "20060101T000000", "developer": "SEGA", "publisher": "SEGA", "family": "Hunting", "arcadesystemname": "atomiswave", "players": "1-2", "md5": "4acdd8c6aa7b57949a7ac87131b905c7", "lang": "en", "region": "us"}}
{"type": "file", "p": "xtrmhunt.zip", "n": "xtrmhunt", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/atomiswave_nonmerged/Atomiswave/xtrmhunt.zip"}], "meta": {"path": "./xtrmhunt.zip", "name": "Extreme Hunting", "desc": "Se puede cazar un total de 6 animales, cada uno con su propia singularidad y animación. Las distintas etapas de la caza de animales se caracterizan por una gran variedad de regiones de caza, todas ellas con magníficas imágenes de fondo. Las condiciones climáticas también entrarán en juego dependiendo de la región. Una vez que hayas completado toda la etapa de animales, podrás cazar en el punto de bonificación único de esa etapa.", "genre": "Disparos con periférico", "image": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhunt-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/videos/xtrmhunt-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhunt-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhunt-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhunt-fanart.jpg", "bezel": "./images/xtrmhunt-bezel.png", "boxback": "Z:/Digistorage/Arley4dCloudMedia/atomiswave/images/xtrmhunt-boxback.jpg", "rating": "0.75", "releasedate": "20040101T000000", "developer": "Sammy Corporation", "publisher": "Sammy Corporation", "arcadesystemname": "atomiswave", "players": "1-2", "md5": "192c3b7c820acebbe37bee0c4d7da115", "lang": "en", "region": "us"}}
