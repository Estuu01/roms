{"type": "file", "p": "Super Pinball Magic (1991)(Loricel).zip", "n": "Super Pinball Magic (1991)(Loricel)", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/Amstrad_GX4000_TOSEC_2012_04_23/Amstrad_GX4000_TOSEC_2012_04_23.zip/Amstrad%20GX4000%20%5BTOSEC%5D%2FAmstrad%20GX4000%20-%20Games%20-%20%5BCPR%5D%20%28TOSEC-v2010-12-08_CM%29%2FSuper%20Pinball%20Magic%20%281991%29%28Loricel%29.zip"}], "meta": {"path": "./Super Pinball Magic (1991)(Loricel).zip", "name": "Super Pinball Magic", "desc": "¡PONGA UN FLIPPER EN SU CONSOLA! Esta magnífica simulación de pinball realmente te hará sentirte encantado. Gracias a sus 12 pinturas, algunas de las cuales incluyen juegos de breakout, una gran cantidad de bonificaciones y bolas extra, \"SUPER\" PINBALL MAGIC es el software que tenemos absolutamente!", "genre": "Pinball", "image": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Super Pinball Magic (1991)(Loricel)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/gx4000/videos/Super Pinball Magic (1991)(Loricel)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Super Pinball Magic (1991)(Loricel)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Super Pinball Magic (1991)(Loricel)-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Super Pinball Magic (1991)(Loricel)-fanart.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/gx4000/manuals/Super Pinball Magic (1991)(Loricel)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Super Pinball Magic (1991)(Loricel)-boxback.jpg", "rating": "0.7", "releasedate": "19910101T000000", "developer": "Loriciel", "publisher": "Loriciel", "players": "1", "md5": "bb89644ecf89b254e46926867c5f802c", "lang": "en"}}
{"type": "file", "p": "Switchblade (1990)(Gremlin).zip", "n": "Switchblade (1990)(Gremlin)", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/Amstrad_GX4000_TOSEC_2012_04_23/Amstrad_GX4000_TOSEC_2012_04_23.zip/Amstrad%20GX4000%20%5BTOSEC%5D%2FAmstrad%20GX4000%20-%20Games%20-%20%5BCPR%5D%20%28TOSEC-v2010-12-08_CM%29%2FSwitchblade%20%281990%29%28Gremlin%29.zip"}], "meta": {"path": "./Switchblade (1990)(Gremlin).zip", "name": "Switchblade", "desc": "La Fireblade, símbolo sagrado del antiguo clan Switchblade, ha sido fragmentada en 16 pedazos por el malvado Havoc - pero dicen que Hiro puede salvarla. Como Hiro, debes recuperar las 16 piezas y restaurar el orgullo de tu gente.\nEl modo de juego es multiplataformas y escaleras. La disposición de los territorios se hace visible a medida que avanzas y pueden contener armas de bonificación y cuartos secretos.", "genre": "Plataformas", "image": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Switchblade (1990)(Gremlin)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/gx4000/videos/Switchblade (1990)(Gremlin)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Switchblade (1990)(Gremlin)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Switchblade (1990)(Gremlin)-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Switchblade (1990)(Gremlin)-fanart.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/gx4000/manuals/Switchblade (1990)(Gremlin)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Switchblade (1990)(Gremlin)-boxback.jpg", "rating": "0.9", "releasedate": "19900101T000000", "developer": "Core Design", "publisher": "Gremlin Graphics Software", "family": "Switchblade", "players": "1", "md5": "99baa70a6fcfb33f53f5312ba008e3f7", "lang": "en"}}
{"type": "file", "p": "Tennis Cup 2 (1990)(Loriciel).zip", "n": "Tennis Cup 2 (1990)(Loriciel)", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/Amstrad_GX4000_TOSEC_2012_04_23/Amstrad_GX4000_TOSEC_2012_04_23.zip/Amstrad%20GX4000%20%5BTOSEC%5D%2FAmstrad%20GX4000%20-%20Games%20-%20%5BCPR%5D%20%28TOSEC-v2010-12-08_CM%29%2FTennis%20Cup%202%20%281990%29%28Loriciel%29.zip"}], "meta": {"path": "./Tennis Cup 2 (1990)(Loriciel).zip", "name": "Tennis Cup 2", "desc": "Esta simulación de tenis recrea todas las reglas del deporte, desde desempates hasta puntos de quiebre. La acción se ve desde detrás de uno de los jugadores, y también presenta una opción de pantalla dividida. Puedes jugar partidos de individuales y dobles en 1,3 o 5 sets. Existen 4 tipos de superficies: pasto, sintético, duro y arcilla. Puedes jugar juegos simples, practicar con el lanzador o jugar una temporada de torneos importantes como los torneos Grand Slam, Masters y la Copa ATP.", "genre": "Deportes / Tenis", "image": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Tennis Cup 2 (1990)(Loriciel)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/gx4000/videos/Tennis Cup 2 (1990)(Loriciel)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Tennis Cup 2 (1990)(Loriciel)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Tennis Cup 2 (1990)(Loriciel)-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Tennis Cup 2 (1990)(Loriciel)-fanart.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/gx4000/manuals/Tennis Cup 2 (1990)(Loriciel)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Tennis Cup 2 (1990)(Loriciel)-boxback.jpg", "rating": "0.6", "releasedate": "19900101T000000", "developer": "Loriciel", "publisher": "Loriciel", "family": "Tennis Cup", "players": "1-2", "md5": "1c365783ca54085dc4b4c1f8edec7fa7", "lang": "en"}}
