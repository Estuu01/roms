{"type": "file", "p": "Barbarian II (1990)(Ocean).zip", "n": "Barbarian II (1990)(Ocean)", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/Amstrad_GX4000_TOSEC_2012_04_23/Amstrad_GX4000_TOSEC_2012_04_23.zip/Amstrad%20GX4000%20%5BTOSEC%5D%2FAmstrad%20GX4000%20-%20Games%20-%20%5BCPR%5D%20%28TOSEC-v2010-12-08_CM%29%2FBarbarian%20II%20%281990%29%28Ocean%29.zip"}], "meta": {"path": "./Barbarian II (1990)(Ocean).zip", "name": "Barbarian II : The Dungeon of Drax", "desc": "El jugador encarna a la princesa Mariana, que lucha con la espada, o a un bárbaro armado con un hacha. Su búsqueda común es perseguir al mago Drax que se refugió en su mazmorra después de su derrota en el primer bárbaro. Para esto, el personaje controlado por el jugador debe cruzar un desierto inhóspito, una red de bodegas y un calabozo antes de enfrentar a Drax en su santuario.", "genre": "Lucha", "image": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Barbarian II (1990)(Ocean)-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/gx4000/videos/Barbarian II (1990)(Ocean)-video.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Barbarian II (1990)(Ocean)-marquee.png", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Barbarian II (1990)(Ocean)-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Barbarian II (1990)(Ocean)-fanart.jpg", "manual": "Z:/Digistorage/Arley4dCloudMedia/gx4000/manuals/Barbarian II (1990)(Ocean)-manual.pdf", "boxback": "Z:/Digistorage/Arley4dCloudMedia/gx4000/images/Barbarian II (1990)(Ocean)-boxback.jpg", "rating": "0.7", "releasedate": "19900101T000000", "developer": "Palace Software", "publisher": "Ocean", "family": "Barbarian (Palace)", "players": "1", "md5": "682d17fa1cb98938db867f4bd43f56ac", "lang": "en"}}
