{"type": "file", "p": "Dead By Daylight.zip", "n": "Dead By Daylight", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/PinballM/pakchunk2174-WindowsNoEditor.pak"}], "meta": {"path": "./Dead By Daylight.zip", "name": "Dead By Daylight", "desc": "Dead by Daylight is an asymmetrical online multiplayer game always played with five people. The 4vs1 gameplay has two teams where the player is either a killer or one of four survivors. Survivors attempt to escape an environment, while the killer needs to stop them. The killer cannot be killed, so the survivors need to work together to outsmart the hunter and get away.", "genre": "Aventura / Terror de Supervivencia", "image": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Dead By Daylight-image.jpg", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Dead By Daylight-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Dead By Daylight-fanart.jpg", "boxback": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Dead By Daylight-boxback.jpg", "releasedate": "20160614T000000", "developer": "Behaviour Digital", "publisher": "Starbreeze", "md5": "c90dbc4b91440357224c80c0e832bc9f", "lang": "en", "video": "Z:/Digistorage/Arley4dCloudMedia/pinballm/videos/Arley4droms.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Dead By Daylight-marquee.png"}}
{"type": "file", "p": "DOOM.zip", "n": "DOOM", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/PinballM/pakchunk2092-WindowsNoEditor.pak"}], "meta": {"path": "./DOOM.zip", "name": "DOOM", "desc": "Doom on PC is a reboot of id Software's cult classic, drawing on the style of the first two installments. You play as a Marine forced to repel a demon invasion on Mars, using an arsenal ranging from shotguns to rocket launchers.", "genre": "Disparos / 1ª persona", "image": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/DOOM-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/pinballm/videos/DOOM-video.mp4", "fanart": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/DOOM-fanart.jpg", "releasedate": "20160513T000000", "developer": "id Software", "publisher": "Bethesda Softworks", "md5": "b62ba66d85d3253d0a66e2539b73a0ae", "lang": "en", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Arley4dRoms.png", "marquee": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/DOOM-marquee.png"}}
{"type": "file", "p": "Duke Nukem.zip", "n": "Duke Nukem", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/PinballM/pakchunk2176-WindowsNoEditor.pak"}], "meta": {"path": "./Duke Nukem.zip", "name": "Duke Nukem", "desc": "Duke Nukem consists of three episodes which were also released separately:\nDuke Nukem: Episode 1 - Shrapnel City\nDuke Nukem: Episode 2 - Mission: Moonbase\nDuke Nukem: Episode 3 - Trapped in the Future", "genre": "Plataformas / Tirador con desplazamiento", "image": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Duke Nukem-image.jpg", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Duke Nukem-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Duke Nukem-fanart.jpg", "boxback": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Duke Nukem-boxback.jpg", "releasedate": "20130702T000000", "developer": "Apogee Software", "publisher": "Interceptor Entertainment", "family": "Duke Nukem", "players": "1", "md5": "610598ef9a9e68fd272a047815a1ba5f", "lang": "en", "video": "Z:/Digistorage/Arley4dCloudMedia/pinballm/videos/Arley4droms.mp4", "marquee": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Duke Nukem-marquee.png"}}
{"type": "file", "p": "Fallout.zip", "n": "Fallout", "ext": ".zip", "parent": "", "urls": [{"u": "https://archive.org/download/PinballM/pakchunk2090-WindowsNoEditor.pak"}], "meta": {"path": "./Fallout.zip", "name": "Fallout", "desc": "Set in the aftermath of a world-wide nuclear war, Fallout will challenge you to survive in an unknown and dangerous world. You will take the role of a Vault-dweller, a person who has grown up in a secluded, underground survival Vault. Circumstances arise that force you to go Outside - to a strange world 80 years after the end of modern civilization. A world of mutants, radiation, gangs and violence.\nYour immediate task is to find a replacement for the broken water purification controller chip. Without that chip, your fellow Vault dwellers are doomed to dehydration or will be forced to leave the safety of the Vault for the Outside.\nThe core of the game revolves around your character. Fallout uses a skill-based system to allow you to fine tune your character. As you gain experience (roughly half from combat, the other half from solving adventure seeds and non-combat events), your character will grow as you determine. Combat in Fallout is tactical turn-based. You can take as much time as you need to make decisions. Choose from different types of attacks, with a variety of weapons and attack skills.", "genre": "Juego de Rol", "image": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Fallout-image.jpg", "video": "Z:/Digistorage/Arley4dCloudMedia/pinballm/videos/Fallout-video.mp4", "thumbnail": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Fallout-thumb.jpg", "fanart": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Fallout-fanart.jpg", "boxback": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Fallout-boxback.jpg", "rating": "0.85", "releasedate": "19971009T000000", "developer": "Interplay", "publisher": "Black Isle Studios", "family": "Fallout", "players": "1", "md5": "4c55a2c786b1713b919635432706ee0c", "lang": "en", "marquee": "Z:/Digistorage/Arley4dCloudMedia/pinballm/images/Fallout-marquee.png"}}
